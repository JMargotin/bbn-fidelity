# Copy to .env.local and fill in. Real production values were recovered from
# `flyctl ssh console -a burgerbynight72 -C 'printenv'` and are already in
# .env.local (which is gitignored).

# ─── App ────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# ─── Database (Supabase Postgres pooler in prod) ────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── better-auth ────────────────────────────────────────
BETTER_AUTH_SECRET=                # 32-byte base64 random, `openssl rand -base64 32`
BETTER_AUTH_URL=http://localhost:3000

# ─── QR signing (for scan tokens) ───────────────────────
QR_SIGNING_SECRET=                 # 32-byte base64 random

# ─── Apple Wallet (PassKit) ─────────────────────────────
APPLE_PASS_TYPE_ID=pass.com.burgerbynight.fidelity
APPLE_TEAM_ID=
APPLE_PASS_WEB_SERVICE_URL=http://localhost:3000   # public HTTPS URL in prod (used by iPhone for sync)
APPLE_PASS_CERT_P12_BASE64=        # base64-encoded .p12 (pass signing cert + key)
APPLE_PASS_CERT_PASSWORD=          # passphrase protecting the .p12
APPLE_WWDR_CERT_PEM_BASE64=        # base64-encoded WWDR intermediate cert (PEM)
